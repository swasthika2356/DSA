import java.util.Stack;

class QueueStackPopFriendly {
    Stack<Integer> s1 = new Stack<>();
    Stack<Integer> s2 = new Stack<>();

    // Enqueue operation
    void enqueue(int data) {

        while (!s1.isEmpty()) {
            s2.push(s1.pop());
        }

        s1.push(data);

        while (!s2.isEmpty()) {
            s1.push(s2.pop());
        }

        System.out.println(data + " inserted.");
    }

    // Dequeue operation (Pop Friendly)
    int dequeue() {

        if (s1.isEmpty()) {
            System.out.println("Queue is Empty");
            return -1;
        }

        return s1.pop();
    }

    public static void main(String[] args) {

        QueueStackPopFriendly q = new QueueStackPopFriendly();

        q.enqueue(10);
        q.enqueue(20);
        q.enqueue(30);

        System.out.println("Deleted: " + q.dequeue());
    }
}





