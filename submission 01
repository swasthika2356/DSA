import java.util.Stack;

class QueueStackPushFriendly {
    Stack<Integer> s1 = new Stack<>();
    Stack<Integer> s2 = new Stack<>();

    // Enqueue operation (Push Friendly)
    void enqueue(int data) {
        s1.push(data);
        System.out.println(data + " inserted.");
    }

    // Dequeue operation
    int dequeue() {
        if (s1.isEmpty()) {
            System.out.println("Queue is Empty");
            return -1;
        }

        while (!s1.isEmpty()) {
            s2.push(s1.pop());
        }

        int value = s2.pop();

        while (!s2.isEmpty()) {
            s1.push(s2.pop());
        }

        return value;
    }

    public static void main(String[] args) {
        QueueStackPushFriendly q = new QueueStackPushFriendly();

        q.enqueue(10);
        q.enqueue(20);
        q.enqueue(30);

        System.out.println("Deleted: " + q.dequeue());
    }
}

