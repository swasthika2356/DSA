import java.util.LinkedList;
import java.util.Queue;

class EnqueueFriendlyStack {

    Queue<Integer> queue1 = new LinkedList<>();
    Queue<Integer> queue2 = new LinkedList<>();


    // Push / Enqueue Friendly operation
    void push(int data) {

        queue1.add(data);

        System.out.println(data + " added");
    }



    // Pop operation
    int pop() {

        if(queue1.isEmpty()) {
            System.out.println("Stack is empty");
            return -1;
        }


        // Move elements except last one
        while(queue1.size() > 1) {

            queue2.add(queue1.remove());
        }


        // Remove last element
        int removed = queue1.remove();


        // Swap queues
        Queue<Integer> temp = queue1;
        queue1 = queue2;
        queue2 = temp;


        return removed;
    }



    // Display
    void display() {

        System.out.println("Stack: " + queue1);
    }



    public static void main(String args[]) {


        EnqueueFriendlyStack s = new EnqueueFriendlyStack();


        s.push(10);
        s.push(20);
        s.push(30);


        s.display();


        System.out.println("Removed: " + s.pop());


        s.display();

    }
}
